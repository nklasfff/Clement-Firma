{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "clement-firma",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const mime={'html':'text/html;charset=utf-8','css':'text/css;charset=utf-8','js':'application/javascript;charset=utf-8','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml'};http.createServer((req,res)=>{let p=path.join(process.cwd(),req.url==='/'?'index.html':req.url);fs.readFile(p,(err,data)=>{if(err){res.writeHead(404);res.end('Not found');}else{const ext=path.extname(p).slice(1);res.writeHead(200,{'Content-Type':mime[ext]||'application/octet-stream','Cache-Control':'no-store, no-cache, must-revalidate'});res.end(data);}});}).listen(8080,()=>console.log('ok'));"],
      "port": 8080
    },
    {
      "name": "familiepraxis",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "/Users/Something/Desktop/FamiliePraxis", "-p", "8090", "-c-1"],
      "port": 8090
    }
  ]
}
